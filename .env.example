# ─── Ninken Environment Configuration ───────────────────────────────
# Copy this file to .env and fill in the values.

# Port the application listens on (inside and outside the container)
NINKEN_PORT=4000

# Public base URL — used for OAuth callbacks and client-side links
NEXT_PUBLIC_BASE_URL=http://localhost:4000

# Anthropic API key for AI-assisted features (optional)
ANTHROPIC_API_KEY=

# OpenAI API key (optional — alternative AI provider)
OPENAI_API_KEY=

# Google Gemini API key (optional — alternative AI provider)
GEMINI_API_KEY=

# AI model to use when ANTHROPIC_API_KEY is set
NINKEN_AI_MODEL=claude-sonnet-4-20250514

# Cookie encryption secret — generate with: openssl rand -hex 32
NINKEN_COOKIE_SECRET=
